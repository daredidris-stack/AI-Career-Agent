DATABASE_URL=sqlite:///./career_agent.db
# Production example: postgresql://user:password@host:5432/career_agent
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=24
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JOOBLE_API_KEY=
AI_MODEL=qwen3:8b
AI_REQUEST_TIMEOUT_SECONDS=45
AI_MAX_RETRIES=1
AI_MAX_PROMPT_CHARACTERS=30000
AI_REQUESTS_PER_HOUR=20
AI_REQUESTS_PER_DAY=100
APP_ENV=development
FRONTEND_URL=http://localhost:5173
REQUIRE_EMAIL_VERIFICATION=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
